# Copy this file to .env on the VPS or your own machine, then fill local values.
# .env is intentionally ignored by Git.

# Server admin page token. Use a long random value in production.
EIKETSU_ADMIN_TOKEN=

# Optional local overrides.
EIKETSU_ENV_ROOT=
EIKETSU_ENV_DB_URL=
EIKETSU_CLIENT_SERVER_URL=http://YOUR_VPS_IP:8000

# Optional browser collection overrides for local debugging.
EIKETSU_AUTH_SOURCE=auto
EIKETSU_BROWSER_PROFILE=
EIKETSU_LOGIN_URL=
EIKETSU_BASE_URL=https://eiketsu-taisen.net
