# Keep source diffs stable across Windows local work and Linux VPS deploys.
* text=auto
.gitattributes text eol=lf

*.py text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
Dockerfile text eol=lf

*.ps1 text eol=crlf
*.bat text eol=crlf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.exe binary
*.db binary
*.sqlite binary
*.sqlite3 binary
